package io.fullerstack.substrates;

import static io.humainary.substrates.api.Substrates.*;
import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;

import java.util.ArrayList;
import java.util.Collections;
import java.util.List;
import java.util.concurrent.CopyOnWriteArrayList;
import java.util.concurrent.CountDownLatch;
import java.util.concurrent.TimeUnit;
import java.util.concurrent.atomic.AtomicInteger;
import java.util.concurrent.atomic.AtomicReference;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

/// Spec compliance tests covering thin areas in the TCK.
///
/// These tests validate MUST/SHOULD requirements from the
/// Substrates Specification (https://github.com/humainary-io/substrates-api-spec)
/// that have minimal TCK coverage.
final class SpecComplianceTest {

  // ═══════════════════════════════════════════════════════════════════════
  // §11.2 Reservoir
  // ═══════════════════════════════════════════════════════════════════════

  @Nested
  @DisplayName ( "§11.2 Reservoir" )
  class ReservoirSpec {

    @Test
    @DisplayName ( "drain returns captures in emission order" )
    void drain_emissionOrder () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.order" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();
      var pipe = conduit.get ( cortex.name ( "ch" ) );

      pipe.emit ( "first" );
      pipe.emit ( "second" );
      pipe.emit ( "third" );

      circuit.await ();

      var captures = reservoir.drain ().toList ();
      assertThat ( captures ).hasSize ( 3 );
      assertThat ( captures.get ( 0 ).emission () ).isEqualTo ( "first" );
      assertThat ( captures.get ( 1 ).emission () ).isEqualTo ( "second" );
      assertThat ( captures.get ( 2 ).emission () ).isEqualTo ( "third" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "drain is incremental — second drain returns only new captures" )
    void drain_incremental () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.incremental" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();
      var pipe = conduit.get ( cortex.name ( "ch" ) );

      pipe.emit ( "batch1-a" );
      pipe.emit ( "batch1-b" );
      circuit.await ();

      var first = reservoir.drain ().toList ();
      assertThat ( first ).hasSize ( 2 );

      pipe.emit ( "batch2-a" );
      circuit.await ();

      var second = reservoir.drain ().toList ();
      assertThat ( second ).hasSize ( 1 );
      assertThat ( second.get ( 0 ).emission () ).isEqualTo ( "batch2-a" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "drain on empty reservoir returns empty" )
    void drain_empty () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.empty" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();

      circuit.await ();

      var captures = reservoir.drain ().toList ();
      assertThat ( captures ).isEmpty ();

      circuit.close ();
    }

    @Test
    @DisplayName ( "drain snapshot not affected by subsequent emissions" )
    void drain_snapshotSemantics () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.snapshot" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();
      var pipe = conduit.get ( cortex.name ( "ch" ) );

      pipe.emit ( "before" );
      circuit.await ();

      var snapshot = reservoir.drain ().toList ();

      pipe.emit ( "after" );
      circuit.await ();

      // snapshot should not contain "after"
      assertThat ( snapshot ).hasSize ( 1 );
      assertThat ( snapshot.get ( 0 ).emission () ).isEqualTo ( "before" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "capture pairs value with channel subject" )
    void capture_pairsValueWithSubject () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.capture" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();

      var name1 = cortex.name ( "channel-a" );
      var name2 = cortex.name ( "channel-b" );
      conduit.get ( name1 ).emit ( "from-a" );
      conduit.get ( name2 ).emit ( "from-b" );
      circuit.await ();

      var captures = reservoir.drain ().toList ();
      assertThat ( captures ).hasSize ( 2 );

      // Each capture should pair with the channel that emitted it
      assertThat ( (Object) captures.get ( 0 ).subject ().name () ).isSameAs ( name1 );
      assertThat ( (Object) captures.get ( 0 ).emission () ).isEqualTo ( "from-a" );
      assertThat ( (Object) captures.get ( 1 ).subject ().name () ).isSameAs ( name2 );
      assertThat ( (Object) captures.get ( 1 ).emission () ).isEqualTo ( "from-b" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "reservoir close clears buffer" )
    void close_clearsBuffer () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "reservoir.close" ) );

      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );
      var reservoir = conduit.reservoir ();
      var pipe = conduit.get ( cortex.name ( "ch" ) );

      pipe.emit ( "captured" );
      circuit.await ();

      // Verify captures exist before close
      assertThat ( reservoir.drain ().toList () ).hasSize ( 1 );

      // Re-capture and close
      pipe.emit ( "to-be-cleared" );
      circuit.await ();
      reservoir.close ();

      // After close, buffer should be cleared
      assertThat ( reservoir.drain ().toList () ).isEmpty ();

      circuit.close ();
    }
  }

  // ═══════════════════════════════════════════════════════════════════════
  // §9.2 Scope
  // ═══════════════════════════════════════════════════════════════════════

  @Nested
  @DisplayName ( "§9.2 Scope" )
  class ScopeSpec {

    @Test
    @DisplayName ( "circuits registered with scope close when scope closes" )
    void close_registeredCircuits () {
      var cortex = cortex ();
      var scope = cortex.scope ( cortex.name ( "scope.circuits" ) );

      var c1 = scope.register ( cortex.circuit ( cortex.name ( "first" ) ) );
      var c2 = scope.register ( cortex.circuit ( cortex.name ( "second" ) ) );
      var c3 = scope.register ( cortex.circuit ( cortex.name ( "third" ) ) );

      scope.close ();

      // After scope close, all circuits should be closed
      // Verify by checking await returns immediately (spec §9.3)
      long start = System.nanoTime ();
      c1.await ();
      c2.await ();
      c3.await ();
      long elapsed = System.nanoTime () - start;
      assertThat ( elapsed ).isLessThan ( 100_000_000L );
    }

    @Test
    @DisplayName ( "scope close is idempotent" )
    void close_idempotent () {
      var cortex = cortex ();
      var scope = cortex.scope ( cortex.name ( "scope.idempotent" ) );

      scope.register ( cortex.circuit ( cortex.name ( "c" ) ) );

      // Multiple closes should be safe
      scope.close ();
      scope.close ();
      scope.close ();
      // No exception = pass
    }

    @Test
    @DisplayName ( "child scope closes when parent closes" )
    void childScope_closesWithParent () {
      var cortex = cortex ();
      var parent = cortex.scope ( cortex.name ( "parent" ) );

      var child = parent.scope ( cortex.name ( "child" ) );
      var circuit = child.register ( cortex.circuit ( cortex.name ( "child-circuit" ) ) );

      parent.close ();

      // Child circuit should be closed (await returns immediately)
      long start = System.nanoTime ();
      circuit.await ();
      long elapsed = System.nanoTime () - start;
      assertThat ( elapsed ).isLessThan ( 100_000_000L );
    }

    @Test
    @DisplayName ( "closure provides block-scoped resource management" )
    void closure_blockScoped () {
      var cortex = cortex ();
      var scope = cortex.scope ( cortex.name ( "scope.closure" ) );

      var circuit = cortex.circuit ( cortex.name ( "closure-circuit" ) );
      var closure = scope.closure ( circuit );

      // Circuit should be open during consume
      closure.consume ( c -> {
        // Should be able to use circuit inside consume
        c.await ();
      } );

      // After consume, circuit should be closed
      long start = System.nanoTime ();
      circuit.await ();
      long elapsed = System.nanoTime () - start;
      assertThat ( elapsed ).isLessThan ( 100_000_000L );

      scope.close ();
    }

    @Test
    @DisplayName ( "closure is single-use" )
    void closure_singleUse () {
      var cortex = cortex ();
      var scope = cortex.scope ( cortex.name ( "scope.singleuse" ) );

      var circuit = cortex.circuit ( cortex.name ( "singleuse-circuit" ) );
      var closure = scope.closure ( circuit );

      closure.consume ( c -> {
      } );
      closure.consume ( c -> {
      } ); // second call should be no-op (circuit already closed)

      scope.close ();
    }
  }

  // ═══════════════════════════════════════════════════════════════════════
  // §10 Conduit
  // ═══════════════════════════════════════════════════════════════════════

  @Nested
  @DisplayName ( "§10 Conduit" )
  class ConduitSpec {

    @Test
    @DisplayName ( "percept lookup returns same instance for same name" )
    void percept_sameNameSameInstance () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "conduit.identity" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );

      var name = cortex.name ( "channel" );
      var pipe1 = conduit.get ( name );
      var pipe2 = conduit.get ( name );

      assertThat ( pipe1 ).isSameAs ( pipe2 );

      circuit.close ();
    }

    @Test
    @DisplayName ( "different names return different percepts" )
    void percept_differentNames () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "conduit.diff" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );

      var pipe1 = conduit.get ( cortex.name ( "a" ) );
      var pipe2 = conduit.get ( cortex.name ( "b" ) );

      assertThat ( pipe1 ).isNotSameAs ( pipe2 );

      circuit.close ();
    }

    @Test
    @DisplayName ( "subscriber discovers channels lazily on first emission" )
    void subscriber_lazyDiscovery () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "conduit.lazy" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );

      var discovered = Collections.synchronizedList ( new ArrayList < String > () );

      conduit.subscribe ( circuit.subscriber (
        cortex.name ( "sub" ),
        ( subject, registrar ) -> {
          discovered.add ( subject.name ().toString () );
          registrar.register ( v -> {
          } );
        }
      ) );

      // No emissions yet — subscriber should not have been called
      circuit.await ();
      assertThat ( discovered ).isEmpty ();

      // First emission to channel "x" — triggers discovery
      conduit.get ( cortex.name ( "x" ) ).emit ( "hello" );
      circuit.await ();
      assertThat ( discovered ).containsExactly ( "x" );

      // Second emission to same channel — no re-discovery
      conduit.get ( cortex.name ( "x" ) ).emit ( "world" );
      circuit.await ();
      assertThat ( discovered ).containsExactly ( "x" );

      // Emission to new channel "y" — triggers discovery again
      conduit.get ( cortex.name ( "y" ) ).emit ( "new" );
      circuit.await ();
      assertThat ( discovered ).containsExactlyInAnyOrder ( "x", "y" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "conduit-level flow applies to all channels" )
    void conduitLevelFlow_appliedToAll () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "conduit.flow" ) );

      var received = Collections.synchronizedList ( new ArrayList < String > () );

      // diff() at conduit level — suppress repeated values per channel
      var conduit = circuit.conduit (
        cortex.name ( "c" ),
        Composer.pipe ( String.class ),
        flow -> flow.diff ()
      );

      conduit.subscribe ( circuit.subscriber (
        cortex.name ( "sub" ),
        ( subject, registrar ) -> registrar.register ( received::add )
      ) );

      var pipeA = conduit.get ( cortex.name ( "a" ) );
      var pipeB = conduit.get ( cortex.name ( "b" ) );

      pipeA.emit ( "x" );
      pipeA.emit ( "x" ); // diff suppresses
      pipeA.emit ( "y" ); // new value passes
      pipeB.emit ( "x" );
      pipeB.emit ( "x" ); // diff suppresses (independent state per channel)

      circuit.await ();

      // Should see: a→x, a→y, b→x (duplicates suppressed per channel)
      assertThat ( received ).containsExactly ( "x", "y", "x" );

      circuit.close ();
    }

    @Test
    @DisplayName ( "subscription close removes subscriber from future emissions" )
    void subscription_close () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "conduit.unsub" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );

      var received = Collections.synchronizedList ( new ArrayList < String > () );

      var subscription = conduit.subscribe ( circuit.subscriber (
        cortex.name ( "sub" ),
        ( subject, registrar ) -> registrar.register ( received::add )
      ) );

      conduit.get ( cortex.name ( "ch" ) ).emit ( "before" );
      circuit.await ();

      subscription.close ();

      conduit.get ( cortex.name ( "ch" ) ).emit ( "after" );
      circuit.await ();

      assertThat ( received ).containsExactly ( "before" );

      circuit.close ();
    }
  }

  // ═══════════════════════════════════════════════════════════════════════
  // §5 Execution Model — additional coverage
  // ═══════════════════════════════════════════════════════════════════════

  @Nested
  @DisplayName ( "§5 Execution Model" )
  class ExecutionModelSpec {

    @Test
    @DisplayName ( "transit queue has priority — cascading emissions complete before next ingress" )
    void transitPriority () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "exec.transit" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( String.class ) );

      var order = Collections.synchronizedList ( new ArrayList < String > () );

      // Subscriber that cascades (emits during callback)
      var cascadePipe = new AtomicReference < Pipe < String > > ();
      conduit.subscribe ( circuit.subscriber (
        cortex.name ( "cascader" ),
        ( subject, registrar ) -> registrar.register ( v -> {
          order.add ( "process:" + v );
          // Cascade: emit a derived value (goes to transit queue)
          if ( v.startsWith ( "trigger" ) && cascadePipe.get () != null ) {
            cascadePipe.get ().emit ( "cascade-from-" + v );
          }
        } )
      ) );

      var pipe = conduit.get ( cortex.name ( "ch" ) );
      cascadePipe.set ( pipe );

      // Emit two ingress items
      pipe.emit ( "trigger-1" );
      pipe.emit ( "ingress-2" );

      circuit.await ();

      // Expected order: trigger-1, cascade-from-trigger-1, ingress-2
      // (cascade completes before next ingress)
      assertThat ( order ).containsExactly (
        "process:trigger-1",
        "process:cascade-from-trigger-1",
        "process:ingress-2"
      );

      circuit.close ();
    }

    @Test
    @DisplayName ( "await after close returns immediately" )
    void awaitAfterClose () {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "exec.await.close" ) );

      circuit.await ();
      circuit.close ();

      // Spec §9.3: "After close(), await() MUST return immediately"
      long start = System.nanoTime ();
      circuit.await ();
      long elapsed = System.nanoTime () - start;

      assertThat ( elapsed ).isLessThan ( 100_000_000L ); // < 100ms
    }

    @Test
    @DisplayName ( "concurrent emitters maintain deterministic ordering" )
    void concurrentEmitters () throws InterruptedException {
      var cortex = cortex ();
      var circuit = cortex.circuit ( cortex.name ( "exec.concurrent" ) );
      var conduit = circuit.conduit ( cortex.name ( "c" ), Composer.pipe ( Integer.class ) );

      var received = Collections.synchronizedList ( new ArrayList < Integer > () );

      conduit.subscribe ( circuit.subscriber (
        cortex.name ( "sub" ),
        ( subject, registrar ) -> registrar.register ( received::add )
      ) );

      var pipe = conduit.get ( cortex.name ( "ch" ) );
      int perThread = 100;
      int threads = 4;
      var latch = new CountDownLatch ( 1 );
      var done = new CountDownLatch ( threads );

      for ( int t = 0; t < threads; t++ ) {
        int base = t * perThread;
        Thread.startVirtualThread ( () -> {
          try { latch.await (); } catch ( InterruptedException e ) { return; }
          for ( int i = 0; i < perThread; i++ ) {
            pipe.emit ( base + i );
          }
          done.countDown ();
        } );
      }

      latch.countDown ();
      done.await ( 5, TimeUnit.SECONDS );
      circuit.await ();

      // All emissions should arrive (no drops)
      assertThat ( received ).hasSize ( threads * perThread );

      circuit.close ();
    }
  }
}
